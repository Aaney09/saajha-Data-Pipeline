
config {
     type: "table",
    tags: "IE"
}

-- create or replace table `impact_evaluation.mtp_daily_monitor_child_wise` as
with hindi_assessment as (select distinct AssesseeActorId,Date(AssessmentTakenOn)dateOfAssessment,if(Level= "BEGINNER",0,safe_cast(regexp_extract(Level,r'\d') as int64)) as hindiLevel
from ${ref("assessment")}
where QuestionText like "%Ask%" and AssessmentId<>6
qualify row_number() over(partition by AssesseeActorId,date(AssessmentTakenOn) order by AssessmentTakenOn desc)=1
)
, math_assessment as (select distinct AssesseeActorId,Date(AssessmentTakenOn)dateOfAssessment, if(Level= "BEGINNER",0,safe_cast(regexp_extract(Level,r'\d') as int64)) as mathlevel
from ${ref("assessment")}
where QuestionText not like  "%Ask%" and AssessmentId <> 6
qualify row_number() over(partition by AssesseeActorId,date(AssessmentTakenOn) order by AssessmentTakenOn desc)=1
)

, childDetails as (select 
distinct 
IEId as childid, OnBoardedUserId as parentid,ProjectId as ProjectId,
safe_cast(regexp_extract(Education,r'\d+') as int64)as childClass,Education
from ${ref("IE")}
where  projectid=1103935
)

, assessments as (
  select *, dateOfAssessment+1 as hindi_content_to_send_on,dateOfAssessment+2 as math_content_to_send_on,
  case  
when c.childClass = 1 and mathLevel>=2 then TRUE
when c.childClass = 2 and mathLevel>=3 then TRUE
when c.childClass >=3 and mathLevel>=4 then TRUE
Else false
end mathFLnAchievedClassWise,
case  
when c.childClass = 1 and hindiLevel>=3 then TRUE
when c.childClass >=2 and hindiLevel>=4 then TRUE
Else false
end hindiFLnAchievedClassWise
from hindi_assessment h
inner join math_assessment m
using(assesseeActorID,dateOfAssessment)
inner join childDetails c
on assesseeActorID=childid)

, lag_dates_mtp as (
  select 
  parentid,
  childid,
  dateOfAssessment,
  lag(dateOfAssessment) over(partition by childid order by dateOfAssessment) as assessmentlagdate
  from assessments
  order by parentid asc, dateOfAssessment asc,assessmentlagdate asc
)

,resultData_mtp as ((select *,if(assessmentlagdate is null, 0,date_diff(dateOfAssessment,assessmentlagdate,day)) assessmentdateDifference,
from lag_dates_mtp
where if(assessmentlagdate is null, 0,date_diff(dateOfAssessment,assessmentlagdate,day))=0)

UNION ALL
(select *,if(assessmentlagdate is null, 0,date_diff(dateOfAssessment,assessmentlagdate,day)) assessmentdateDifference,
from lag_dates_mtp
where if(assessmentlagdate is null, 0,date_diff(dateOfAssessment,assessmentlagdate,day))>=25)
order by parentid  desc)


 ,result_mtp as (select *, row_number() over(partition by childid order by dateOfAssessment asc)rn
from resultData_mtp
order by parentid asc,rn asc)










,mtp_assessement_wise as (
select 
parentid,
childid,
MAX(IF(rn = 1, dateOfAssessment, NULL)) AS assessment_1,
  MAX(IF(rn = 2, dateOfAssessment, NULL)) AS assessment_2,
  MAX(IF(rn = 3, dateOfAssessment, NULL)) AS assessment_3,
  MAX(IF(rn = 4, dateOfAssessment, NULL)) AS assessment_4,
  MAX(IF(rn = 5, dateOfAssessment, NULL)) AS assessment_5,
  MAX(IF(rn = 6, dateOfAssessment, NULL)) AS assessment_6,
  MAX(IF(rn = 7, dateOfAssessment, NULL)) AS assessment_7

from result_mtp
group by 1,2
)
-- select *
-- from mtp_assessement_wise
-- where childid in (103260143738005984,
-- 103260143738127111,
-- 103260143738764436,
-- 103260143739198759,
-- 103260143739473702,
-- 103260143739541801)











, extraction_dates as (
  select 
       DATE(r.extractionDate)
    -- ELSE DATE(r.rescheduledTime)
   extractionDate,
cohort,
r.assignedTo as volunteer_schedule,
count(distinct r.childid) as total_call_schedule
-- r.childid,
-- r.category
-- count(distinct r.childid) as total_call_schedule
from `impact_evaluation.mtp_daily_roster` r

inner join ${ref("impact_evaluation_main_data")} ie_main
on safe_cast(r.parentid as int64)=ie_main.parentid
where date(r.rescheduledTime) between '2025-12-25' and current_date("Asia/Kolkata")
and LOWER(r.category) LIKE '%floating%' 

group by all

union all
  select 
       DATE(r.rescheduledTime)
    -- ELSE DATE(r.rescheduledTime)
   extractionDate,
cohort,
r.assignedTo as volunteer_schedule,
count(distinct r.childid) as total_call_schedule
-- r.childid,
-- r.category
-- count(distinct r.childid) as total_call_schedule
from `impact_evaluation.mtp_daily_roster` r

inner join ${ref("impact_evaluation_main_data")} ie_main
on safe_cast(r.parentid as int64)=ie_main.parentid
where date(r.rescheduledTime) between '2025-12-25' and current_date("Asia/Kolkata")
and LOWER(r.category) not LIKE '%floating%' 

group by all


-- where extractionDate=current_date("Asia/Kolkata")
)


-- ,mtp_final as (
, all_attempts as (  
select
maw.parentid,
maw.childid,
-- date(mtp.inserted_at) as attempted_date,
mtp.assignedto as volunteer_number,
cohort,
count(distinct
if(assessment_1 is not null,
if(date(mtp.inserted_at)>assessment_1 and date(mtp.inserted_at)<ifnull(assessment_2,'2026-12-01'),mtp.inserted_at,null) 
,null)) as attempted_calls_R1,

count(distinct
  if(assessment_2 is not null,
if(date(mtp.inserted_at)>assessment_2 and date(mtp.inserted_at)<ifnull(assessment_3,'2026-12-01'),mtp.inserted_at,null)
,null )) as attempted_calls_R2,

count(distinct
  if(assessment_3 is not null,
if(date(mtp.inserted_at)>assessment_3 and date(mtp.inserted_at)<ifnull(assessment_4,'2026-12-01'),mtp.inserted_at,null)
,null )) as attempted_calls_R3,

count(distinct
  if(assessment_4 is not null,
if(date(mtp.inserted_at)>assessment_4 and date(mtp.inserted_at)<ifnull(assessment_5,'2026-12-01'),mtp.inserted_at,null)
,null )) as attempted_calls_R4,

count(distinct
  if(assessment_5 is not null,
if(date(mtp.inserted_at)>assessment_5 and date(mtp.inserted_at)<ifnull(assessment_6,'2026-12-01'),mtp.inserted_at,null)
,null )) as attempted_calls_R5,


count(distinct
  if(assessment_6 is not null,
if(date(mtp.inserted_at)>assessment_6 and date(mtp.inserted_at)<ifnull(assessment_7,'2026-12-01'),mtp.inserted_at,null)
,null )) as attempted_calls_R6,

from mtp_assessement_wise maw
left join  `saajhadata.impact_evaluation.mtp_calls`  mtp
on maw.parentid=safe_cast(mtp.parentid as int64)
and  date(inserted_at)>'2025-11-25'

left join `dataform.impact_evaluation_main_data` ie_main
on maw.parentid=ie_main.parentid

group by all
)


,resolved_calls as(
  -----------------------------------------------------------------------------------------------------------------------------
--RESOLVED 
-----------------------------------------------------------------------------------------------------------------------------
select
maw.parentid,
maw.childid,
-- date(mtp_resolve.inserted_at) as attempted_date,
mtp_resolve.assignedto as volunteer_number,
cohort,
count( distinct
if(assessment_1 is not null,
if(date(mtp_resolve.inserted_at)>assessment_1 and date(mtp_resolve.inserted_at)<ifnull(assessment_2,'2026-12-01'),mtp_resolve.parentid,null) 
,null)) as resolved_calls_R1,

count(distinct
  if(assessment_2 is not null,
if(date(mtp_resolve.inserted_at)>assessment_2 and date(mtp_resolve.inserted_at)<ifnull(assessment_3,'2026-12-01'),mtp_resolve.parentid,null)
,null )) as resolved_calls_R2,

count(distinct
  if(assessment_3 is not null,
if(date(mtp_resolve.inserted_at)>assessment_3 and date(mtp_resolve.inserted_at)<ifnull(assessment_4,'2026-12-01'),mtp_resolve.parentid,null)
,null )) as resolved_calls_R3,

count( distinct
  if(assessment_4 is not null,
if(date(mtp_resolve.inserted_at)>assessment_4 and date(mtp_resolve.inserted_at)<ifnull(assessment_5,'2026-12-01'),mtp_resolve.parentid,null)
,null )) as resolved_calls_R4,

count(distinct
  if(assessment_5 is not null,
if(date(mtp_resolve.inserted_at)>assessment_5 and date(mtp_resolve.inserted_at)<ifnull(assessment_6,'2026-12-01'),mtp_resolve.parentid,null)
,null )) as resolved_calls_R5,


count(distinct
  if(assessment_6 is not null,
if(date(mtp_resolve.inserted_at)>assessment_6 and date(mtp_resolve.inserted_at)<ifnull(assessment_7,'2026-12-01'),mtp_resolve.parentid,null)
,null )) as resolved_calls_R6,


------------------------------------------------------------------------------------------------
-- GETTING RESOLVED DATES
------------------------------------------------------------------------------------------------
max(
if(assessment_1 is not null,
if(date(mtp_resolve.inserted_at)>assessment_1 and date(mtp_resolve.inserted_at)<ifnull(assessment_2,'2026-12-01'),DATE(mtp_resolve.INSERTED_AT),null) 
,null)) as resolved_date_R1,

max(if(assessment_2 is not null,
if(date(mtp_resolve.inserted_at)>assessment_2 and date(mtp_resolve.inserted_at)<ifnull(assessment_3,'2026-12-01'),DATE(mtp_resolve.INSERTED_AT),null)
,null )) as resolved_date_R2,

max(if(assessment_3 is not null,
if(date(mtp_resolve.inserted_at)>assessment_3 and date(mtp_resolve.inserted_at)<ifnull(assessment_4,'2026-12-01'),DATE(mtp_resolve.INSERTED_AT),null)
,null )) as resolved_date_R3,

max(if(assessment_4 is not null,
if(date(mtp_resolve.inserted_at)>assessment_4 and date(mtp_resolve.inserted_at)<ifnull(assessment_5,'2026-12-01'),DATE(mtp_resolve.INSERTED_AT),null)
,null )) as resolved_date_R4,

max(if(assessment_5 is not null,
if(date(mtp_resolve.inserted_at)>assessment_5 and date(mtp_resolve.inserted_at)<ifnull(assessment_6,'2026-12-01'),DATE(mtp_resolve.INSERTED_AT),null)
,null )) as resolved_date_R5,


max(if(assessment_6 is not null,
if(date(mtp_resolve.inserted_at)>assessment_6 and date(mtp_resolve.inserted_at)<ifnull(assessment_7,'2026-12-01'),date(mtp_resolve.INSERTED_AT),null)
,null )) as resolved_date_R6
--------------------------------------------------------------------------------------------------------

from mtp_assessement_wise maw
left join (select * from `saajhadata.impact_evaluation.mtp_calls` 
where status like 'RESOLVED' and date(inserted_at)>'2025-11-25' ) mtp_resolve
on maw.parentid=safe_cast(mtp_resolve.parentid as int64)

left join `dataform.impact_evaluation_main_data` ie_main
on maw.parentid=ie_main.parentid

group by all
)
-- ,volunteer_details as (
select
parentid,
safe_cast(childid as string) as childid,
cohort,
resolved_date_R1,
resolved_date_R2,
resolved_date_R3,
resolved_date_R4,
resolved_date_R5,
resolved_date_R6,

-- attempted_date,
 attempted_calls_R1  as round_1_attempted,
 attempted_calls_R2  as round_2_attempted,
 attempted_calls_R3  as round_3_attempted,
 attempted_calls_R4  as round_4_attempted,
 attempted_calls_R5  as round_5_attempted,
 attempted_calls_R6  as round_6_attempted,

-------------------------------------------------------------------------

 resolved_calls_R1  as round_1_resolved,
 resolved_calls_R2  as round_2_resolved,
 resolved_calls_R3  as round_3_resolved,
 resolved_calls_R4  as round_4_resolved,
 resolved_calls_R5  as round_5_resolved,
 resolved_calls_R6  as round_6_resolved,

from all_attempts
left join resolved_calls 
using(parentid,childid,cohort)
group by all

-- )










