---------------------------------------------------------------------------------------------------
--Combining the child,level-wise and worksheet sent_date-wise math and hindi worksheet 
,worksheet_cte_all as (

select
childid,
level,
worksheet,
sent_at as sent_date,
UniqueUserSentTo,
UniqueUserclickedBy,
uniqueUserCompletedBy,
"hindi" as subject
from cte_hindi

union all

select
childid,
level,
worksheet,
sent_at as sent_date,
UniqueUserSentTo,
UniqueUserclickedBy,
uniqueUserCompletedBy,
"math" as subject
from cte_math


) 


,parent_rounds as (
select
safe_cast(assesseeActorId as int64) as childid,


date(Round_1_Assessment) as r1,
date(Round_2_Assessment) as r2,
date(Round_3_Assessment) as r3,
date(Round_4_Assessment) as r4,
date(Round_5_Assessment) as r5,
date(Round_6_Assessment) as r6,
date(Round_7_Assessment) as r7,
date(Round_8_Assessment) as r8,
date(Round_9_Assessment) as r9,
date(Round_10_Assessment) as r10

from ${ref("parent_journey_2026_27")}
where assesseeActorId is not null
)

--combining child's worksheet and round details together
,base_round as (
select
w.*,
-- p.cohort,
p.r1,p.r2,p.r3,p.r4,p.r5,p.r6,p.r7,p.r8 ,p.r9,p.r10 --rounds assessment date

from worksheet_cte_all as w
inner join parent_rounds as p  
on w.childid = p.childid

) 


--assigning round number based on the worksheet-sent date
,round_tag as (

select 
*,
case
when r2 is null and sent_date >= r1 then 1
when r2 is not null and sent_date between r1 and r2 then 1

when r3 is null and sent_date >= r2 then 2
when r3 is not null and sent_date between r2 and r3 then 2

when r4 is null and sent_date >= r3 then 3
when r4 is not null and sent_date between r3 and r4 then 3

when r5 is null and sent_date >= r4 then 4
when r5 is not null and sent_date between r4 and r5 then 4

when r6 is null and sent_date >= r5 then 5
when r6 is not null and sent_date between r5 and r6 then 5

when r7 is null and sent_date >= r6 then 6
when r7 is not null and sent_date between r6 and r7 then 6


when r8 is null and sent_date >= r7 then 7
when r8 is not null and sent_date between r7 and r8 then 7


when r9 is null and sent_date >= r8 then 8
when r9 is not null and sent_date between r8 and r9 then 8


when r9 is null and sent_date >= r8 then 8
when r9 is not null and sent_date between r8 and r9 then 8




when sent_date >= r9 then 9

end as round_number

from base_round
) 
----------------------------------------------------------------------------
-- FOR GAMIFIED WORKSHEET SENT COUNT
----------------------------------------------------------------------------

,base_round_gam as (
select
w.*,

p.r1,p.r2,p.r3,p.r4,p.r5,p.r6,p.r7,p.r8 ,p.r9,p.r10 --rounds assessment date

from final_game_cte as w
inner join parent_rounds as p  
on w.childid = p.childid

) 


--assigning round number based on the worksheet-sent date
,round_tag_gam as (

select 
*,
CASE
  WHEN r2 IS NULL AND sent_date >= r1 THEN 1
  WHEN r2 IS NOT NULL AND sent_date >= r1 AND sent_date < r2 THEN 1

  WHEN r3 IS NULL AND sent_date >= r2 THEN 2
  WHEN r3 IS NOT NULL AND sent_date >= r2 AND sent_date < r3 THEN 2

  WHEN r4 IS NULL AND sent_date >= r3 THEN 3
  WHEN r4 IS NOT NULL AND sent_date >= r3 AND sent_date < r4 THEN 3

  WHEN r5 IS NULL AND sent_date >= r4 THEN 4
  WHEN r5 IS NOT NULL AND sent_date >= r4 AND sent_date < r5 THEN 4

  WHEN r6 IS NULL AND sent_date >= r5 THEN 5
  WHEN r6 IS NOT NULL AND sent_date >= r5 AND sent_date < r6 THEN 5

  WHEN r7 IS NULL AND sent_date >= r6 THEN 6
  WHEN r7 IS NOT NULL AND sent_date >= r6 AND sent_date < r7 THEN 6

  WHEN r8 IS NULL AND sent_date >= r7 THEN 7
  WHEN r8 IS NOT NULL AND sent_date >= r7 AND sent_date < r8 THEN 7

  WHEN r9 IS NULL AND sent_date >= r8 THEN 8
  WHEN r9 IS NOT NULL AND sent_date >= r8 AND sent_date < r9 THEN 8

  WHEN sent_date >= r9 THEN 9

end as round_number

from base_round_gam
) 
-- select * from round_tag_gam
-- where childid=103260143767216983
-------------------------------------------------------------------------------------------------------------


--count of worksheet sent,clicked and completed,cohort,round,level,subject wise
,round_level_metrics as (

select
childid,

round_number,
subject,
level,


sum(if(UniqueUserSentTo>1,1,UniqueUserSentTo)) as worksheet_sent,
sum(if(UniqueUserclickedBy>1,1,UniqueUserclickedBy)) as worksheet_clicked,
sum(if(uniqueUserCompletedBy>1,1,uniqueUserCompletedBy)) as worksheet_completed

from round_tag
where round_number is not null
group by 1,2,3,4
)
,round_gam_metrics AS (
SELECT
    childid,
    round_number,
    subject,
    worksheet_sent_gam,
    unique_worksheet_clicked,
 unique_worksheet_submitted

FROM round_tag_gam
WHERE round_number IS NOT NULL
-- GROUP BY 1,2,3
)

-- select *
-- from round_gam_metrics
-- where childid=103260143767216983
, all_child_round as (
  select
  childid,
  round_number,
  subject
  from round_level_metrics
  union all 
  select
  childid,
  round_number,
  subject
  from round_gam_metrics

)
----------------------------------------------------------------
--QUERY
----------------------------------------------------------------
, final_data as (
select
distinct all_id.childid,
-- cohort,
all_id.round_number,
all_id.subject,
-- worksheet_sent_gam,
-- level,
ifnull(rtg.worksheet_sent_gam,0)+ifnull(rlm.worksheet_sent,0) as worksheet_sent,

-- worksheet_sent,
   ifnull(rlm.worksheet_clicked,0)+ifnull(rtg.unique_worksheet_clicked,0) as worksheet_clicked,
   ifnull(rlm.worksheet_completed,0)+ifnull(rtg.unique_worksheet_submitted,0) as worksheet_completed

-- round((worksheet_completed/worksheet_sent)*100,2) as engagement_percentage,  --engagement percentage

-- case
-- when round((worksheet_completed/worksheet_sent)*100,2)>70.0 then "High"
-- when round((worksheet_completed/worksheet_sent)*100,2) between 40.0 and 70.0 then "Medium"
-- else "Low"
-- end as bucket

from all_child_round all_id

left join round_level_metrics rlm
on all_id.childid=rlm.childid
and all_id.subject=rlm.subject
and all_id.round_number=rlm.round_number

left join round_gam_metrics rtg

on all_id.childid=rtg.childid 
and all_id.subject=rtg.subject
and all_id.round_number=rtg.round_number
-- and all_id.round_number is not null
order by round_number,subject
)
select
*,

round((worksheet_completed/worksheet_sent)*100,2) as engagement_percentage,  --engagement percentage

case
when round((worksheet_completed/worksheet_sent)*100,2)>70.0 then "High"
when round((worksheet_completed/worksheet_sent)*100,2) between 40.0 and 70.0 then "Medium"
else "Low"
end as bucket

from final_data