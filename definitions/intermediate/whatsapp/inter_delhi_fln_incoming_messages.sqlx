config {
    type:"table",
    tags: "wa_daily",
    schema: "whatsapp",
    description: "Incoming message details of users on Delhi FLN Number; Created on 04/26"
}
select 
 phone_number,
    id,
    uuid, 
    chat_id,
    message_type, 
     message_content, 
   sent_at,
     saajha_whatsapp_number,
    wa_number_purpose,
    context_id,
from ${ref("std_delhi_fln_incoming_messages")}
